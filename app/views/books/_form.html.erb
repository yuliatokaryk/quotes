<% if @book.errors.any? %>
  <div class="p-4 mb-4 text-sm text-red-700 bg-red-100 rounded-lg dark:bg-red-200 dark:text-red-800" role="alert">
    <ul class="list-disc">
      <% @book.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="w-full max-w-xs">
  <%= form_with(model: @book, local:true) do |f| %>
    <div class="mb-4">
      <%= f.label t('books.title'), class: "block text-gray-700 text-sm font-bold mb-2" %><br>
      <%= f.text_field :title, class:"shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %><br>
    </div>
    <div class="mb-4">
      <%= f.label t('books.year'), class: "block text-gray-700 text-sm font-bold mb-2" %><br>
      <%= f.number_field :year_of_publication, class:"shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %><br>
    </div>
    <div class="mb-4">
      <%= f.label t('books.wiki_url'), class: "block text-gray-700 text-sm font-bold mb-2" %><br>
      <%= f.text_field :wikipedia_url, class:"shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %><br>
    </div>
    <div class="mb-4">
      <%= f.label t('books.gr_url'), class: "block text-gray-700 text-sm font-bold mb-2" %><br>
      <%= f.text_field :goodreads_url, class:"shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %><br>
    </div>
    <div class="mb-4">
      <%= f.label t('books.author'), class: "block text-gray-700 text-sm font-bold mb-2" %><br>
      <%= f.select :author_id, Author.all.collect {|a| [ a.first_name, a.id ] }, { include_blank: true }, class:"shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus:outline-none focus:shadow-outline" %><br>
    </div>
    <div class="mb-4">      
      <%= f.submit t('actions.submit'), class:"bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline" %>
    </div>
  <% end %>
</div>
